{
  "name": "Análisis de Datos con Python",
  "build": {
    "context": "..",
    "dockerfile": "../Dockerfile"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.pylance",
        "ms-toolsai.jupyter",
        "ms-toolsai.jupyter-keymap",
        "ms-toolsai.jupyter-renderers"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/opt/conda/bin/python",
        "jupyter.kernels.filter": [],
        "jupyter.notebookFileRoot": "${workspaceFolder}"
      }
    }
  },
  "forwardPorts": [8888],
  "postCreateCommand": "echo 'Entorno listo. Abre un notebook desde el explorador de archivos.'",
  "remoteUser": "jovyan"
}
